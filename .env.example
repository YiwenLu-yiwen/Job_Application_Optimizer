# Default provider-neutral LLM settings. Role-specific values below override these.
LLM_API_KEY=
LLM_MODEL=
LLM_BASE_URL=
# Use "chat" for many local/open-model OpenAI-compatible endpoints.
LLM_API_MODE=responses

# Optional role-specific overrides. Only set the roles you want to route differently.
# reasoning: requirements extraction, evidence mapping, ATS scoring, and gap diagnosis.
LLM_REASONING_MODEL=
LLM_REASONING_BASE_URL=
LLM_REASONING_API_KEY=
LLM_REASONING_API_MODE=

# writer: tailored resume, cover letter, and local resume editor retries.
LLM_WRITER_MODEL=
LLM_WRITER_BASE_URL=
LLM_WRITER_API_KEY=
LLM_WRITER_API_MODE=

# interview/cv/metadata inherit defaults unless these are set.
LLM_INTERVIEW_MODEL=
LLM_CV_MODEL=
LLM_METADATA_MODEL=

# ---------------------------------------------------------------------------
# Provider examples
# ---------------------------------------------------------------------------
# Copy one block below and uncomment it when you want to route a role to that
# provider. Model names change over time, so verify the model ID in the provider
# console/docs before a production run.

# Example: DeepSeek for reasoning tasks.
# LLM_REASONING_MODEL=deepseek-reasoner
# LLM_REASONING_BASE_URL=https://api.deepseek.com/v1
# LLM_REASONING_API_KEY=your_deepseek_api_key
# LLM_REASONING_API_MODE=chat

# Example: Qwen / Alibaba Cloud Model Studio DashScope for reasoning tasks.
# Mainland China endpoint:
# LLM_REASONING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# International/Singapore endpoint:
# LLM_REASONING_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# LLM_REASONING_MODEL=qwen-plus
# LLM_REASONING_API_KEY=your_dashscope_api_key
# LLM_REASONING_API_MODE=chat

# Example: Gemini API OpenAI-compatible endpoint for reasoning or writing.
# LLM_REASONING_MODEL=gemini-2.5-flash
# LLM_REASONING_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_REASONING_API_KEY=your_gemini_api_key
# LLM_REASONING_API_MODE=chat

# Example: local OpenAI-compatible server, such as vLLM, SGLang, LM Studio, or
# an internal NVIDIA NIM-style endpoint.
# LLM_REASONING_MODEL=your-local-model-id
# LLM_REASONING_BASE_URL=http://localhost:8000/v1
# LLM_REASONING_API_KEY=local-or-placeholder-key
# LLM_REASONING_API_MODE=chat

TARGET_RESUME_SCORE=80
PROMPT_CHAR_LIMIT=0
JOB_FETCH_MODE=browser
JOB_FETCH_MIN_TEXT_CHARS=800
JOB_FETCH_BROWSER_TIMEOUT_MS=30000
JOB_FETCH_BROWSER_WAIT_MS=1500
JOB_FETCH_BROWSER_HEADLESS=true
REWRITE_LIFT_THRESHOLD=3
